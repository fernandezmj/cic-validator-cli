{
  "name": "cic-validator-cli",
  "version": "1.0.0",
  "description": "CIC submission file (HD/ID) validator — CLI",
  "type": "module",
  "bin": {
    "cic-validate": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsc && node dist/index.js",
    "validate": "tsc && node dist/index.js test-data/test-submit-data.txt",
    "dev": "tsx src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
